# --- MANDATORY FOR SUBMISSION ---
# The URL for the LLM (OpenAI or your local provider)
API_BASE_URL=https://api.openai.com/v1

# The model name (e.g., gpt-4o for submission, llama3 for local)
MODEL_NAME=gpt-4o

# Your Hugging Face Token / OpenAI Key
HF_TOKEN=your_token_here

# --- LOCAL ENVIRONMENT SETTINGS ---
# Internal port for the FastAPI server
PORT=7860

# --- LOCAL TESTING (Ollama) ---
# Uncomment these to test without using OpenAI credits
# API_BASE_URL=http://localhost:11434/v1
# MODEL_NAME=llama3
# HF_TOKEN=ollama